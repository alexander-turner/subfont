{
  "name": "@turntrout/subfont",
  "version": "1.0.0",
  "description": "Automatically subset web fonts to only the characters used on your pages. Fork of Munter/subfont with modern defaults.",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "lint": "eslint . && prettier --check '**/*.{js,md}'",
    "test": "mocha && npm run lint",
    "coverage": "nyc --reporter=lcov --reporter=text -- mocha",
    "check-coverage": "nyc check-coverage",
    "preversion": "offline-github-changelog --next=${npm_new_version} > CHANGELOG.md && git add CHANGELOG.md",
    "prepare": "husky || true"
  },
  "bin": {
    "subfont": "lib/cli.js"
  },
  "main": "lib/subfont.js",
  "files": [
    "lib",
    "*.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexander-turner/subfont.git"
  },
  "keywords": [
    "google",
    "font",
    "fonts",
    "webfont",
    "webfonts",
    "subset",
    "subsetting",
    "commandline",
    "cli",
    "automation",
    "woff",
    "woff2",
    "preload"
  ],
  "author": "Alexander Turner",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexander-turner/subfont/issues"
  },
  "homepage": "https://github.com/alexander-turner/subfont#readme",
  "dependencies": {
    "@gustavnikolaj/async-main-wrap": "^3.0.1",
    "@hookun/parse-animation-shorthand": "^0.1.5",
    "@puppeteer/browsers": "^2.0.0",
    "assetgraph": "7.13.0",
    "css-font-parser": "^2.0.0",
    "css-font-weight-names": "^0.2.1",
    "css-list-helpers": "^2.0.0",
    "font-snapper": "^1.2.0",
    "font-tracer": "^3.7.0",
    "fontverter": "^2.0.0",
    "harfbuzzjs": "^0.5.0",
    "jsdom": "^16.5.3",
    "lines-and-columns": "^1.1.6",
    "memoizesync": "^1.1.1",
    "p-limit": "^3.0.0",
    "parse5": "^7.0.0",
    "postcss": "^8.3.11",
    "postcss-value-parser": "^4.0.2",
    "pretty-bytes": "^5.1.0",
    "puppeteer-core": "^24.39.1",
    "specificity": "^0.4.1",
    "subset-font": "~2.3.0",
    "urltools": "^0.4.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "canvas": "npm:@napi-rs/canvas@^0.1.97",
    "combos": "^0.2.0",
    "coveralls": "^3.0.9",
    "css-generators": "^0.2.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-mocha": "^10.0.0",
    "html-generators": "^1.0.3",
    "httpception": "^3.0.0",
    "husky": "^9.1.7",
    "magicpen-prism": "^3.0.2",
    "mocha": "^11.0.0",
    "neostandard": "^0.12.0",
    "nyc": "^15.1.0",
    "offline-github-changelog": "^1.6.1",
    "prettier": "^3.0.0",
    "proxyquire": "^2.1.1",
    "puppeteer": "^24.39.1",
    "sinon": "^19.0.0",
    "unexpected": "^11.8.1",
    "unexpected-check": "^2.3.1",
    "unexpected-resemble": "^5.0.1",
    "unexpected-set": "^2.0.1",
    "unexpected-sinon": "^10.11.2"
  },
  "pnpm": {
    "overrides": {
      "canvas": "npm:@napi-rs/canvas@^0.1.97"
    },
    "onlyBuiltDependencies": [
      "core-js",
      "es5-ext",
      "puppeteer",
      "unrs-resolver"
    ]
  }
}
